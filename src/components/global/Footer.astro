---
import { company, type Locale } from '../../data/company';
import { footerNav } from '../../data/navigation';
import { useTranslations, homePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const socialLinks = [
  { label: 'GitHub', url: company.social.github },
  { label: 'LinkedIn', url: company.social.linkedin },
  { label: 'X', url: company.social.x },
  { label: 'Instagram', url: company.social.instagram },
  { label: 'YouTube', url: company.social.youtube },
].filter((s) => s.url !== '');
---

<footer class="site-footer on-dark">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={homePath(locale)} aria-label={company.name}>
          <img src="/brand/logo-light.svg" alt="" width="89" height="35" />
          <span class="visually-hidden">{company.name}</span>
        </a>
        <p>{company.description[locale]}</p>
      </div>

      <nav class="footer-nav" aria-label={t('nav.menu')}>
        <ul>
          {
            footerNav.map((item) => (
              <li>
                <a href={item.href[locale]}>{item.label[locale]}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      {
        (socialLinks.length > 0 || company.contact.email) && (
          <div class="footer-social">
            {company.contact.email && (
              <a href={`mailto:${company.contact.email}`}>{company.contact.email}</a>
            )}
            <ul>
              {socialLinks.map((s) => (
                <li>
                  <a href={s.url} rel="noopener noreferrer" target="_blank">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <div class="footer-bottom">
      <span class="footer-rule" aria-hidden="true"></span>
      <p class="footer-copy">
        © {year} {company.name}. {t('footer.rights')}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-dark);
    color: var(--color-white);
    padding-block: var(--space-9) var(--space-6);
    margin-top: var(--space-9);
  }

  .footer-top {
    display: grid;
    gap: var(--space-7);
  }

  .footer-brand p {
    margin-top: var(--space-4);
    max-width: 36ch;
  }

  .footer-nav ul,
  .footer-social ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .footer-nav a,
  .footer-social a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--duration-base) var(--ease-standard);
  }

  .footer-nav a:hover,
  .footer-social a:hover {
    color: var(--color-cyan);
  }

  .footer-social {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .footer-bottom {
    margin-top: var(--space-8);
  }

  .footer-rule {
    display: block;
    height: 2px;
    width: 56px;
    border-radius: var(--radius-pill);
    background: var(--gradient-brand);
    margin-bottom: var(--space-5);
  }

  .footer-copy {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.55);
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
