---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../data/company';
import { getCategory } from '../../data/categories';
import { useTranslations, projectPath } from '../../i18n/utils';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
  /** Sobrescribe la variante del frontmatter (p. ej. 'featured' en portada). */
  variant?: CollectionEntry<'projects'>['data']['layoutVariant'];
  headingLevel?: 'h2' | 'h3';
}

const { project, locale, variant, headingLevel = 'h3' } = Astro.props;
const t = useTranslations(locale);
const data = project.data;
const category = getCategory(data.category);
const layout = variant ?? data.layoutVariant;
const href = projectPath(locale, data.slug);
const Heading = headingLevel;
---

<article class:list={['project-preview', `variant-${layout}`]}>
  <a href={href} class="cover-link" tabindex="-1" aria-hidden="true">
    <img
      src={data.cover}
      alt={data.coverAlt}
      width="1280"
      height="800"
      loading={layout === 'featured' ? 'eager' : 'lazy'}
    />
  </a>

  <div class="preview-body">
    <p class="preview-meta meta">
      <span class="preview-category">{category.label[locale]}</span>
      <span aria-hidden="true">·</span>
      <span>{data.year}</span>
      {data.example && <span class="badge badge-example">{t('projects.example')}</span>}
    </p>

    <Heading class="preview-title">
      <a href={href}>{data.title}</a>
    </Heading>

    <p class="preview-excerpt">{data.excerpt}</p>

    {
      data.technologies.length > 0 && (
        <ul class="preview-tech" aria-label={t('projects.tech')}>
          {data.technologies.map((tech) => (
            <li>{tech}</li>
          ))}
        </ul>
      )
    }

    <div class="preview-actions">
      <a href={href} class="link-editorial">{t('cta.viewProject')}</a>
      {
        data.demoUrl && (
          <a
            href={data.demoUrl}
            class="link-editorial link-demo"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('cta.openDemo')}
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-preview {
    display: grid;
    gap: var(--space-5);
  }

  .cover-link {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface-soft);
  }

  .cover-link img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-standard);
  }

  @media (hover: hover) {
    .project-preview:hover .cover-link img {
      transform: scale(1.03);
    }
  }

  .preview-body {
    display: grid;
    gap: var(--space-3);
    align-content: start;
    justify-items: start;
  }

  .preview-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .preview-category {
    font-weight: 600;
    color: var(--color-violet);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--font-size-xs);
  }

  .preview-title {
    font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl));
  }

  .preview-title a {
    color: var(--color-ink-900);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-standard);
  }

  .preview-title a:hover {
    color: var(--color-violet);
  }

  .preview-excerpt {
    color: var(--color-text-muted);
    max-width: 52ch;
  }

  .preview-tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .preview-tech li {
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-3);
  }

  .preview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    margin-top: var(--space-2);
  }

  /* --- Variantes (spec §2.2 / §20) --- */

  @media (min-width: 768px) {
    .variant-featured,
    .variant-split-left {
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
      align-items: center;
      gap: var(--space-7);
    }

    .variant-split-right {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      align-items: center;
      gap: var(--space-7);
    }

    .variant-split-right .cover-link {
      order: 2;
    }

    .variant-split-right .preview-body {
      order: 1;
    }

    .variant-wide .preview-body {
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      column-gap: var(--space-7);
    }

    .variant-wide .preview-title,
    .variant-wide .preview-meta {
      grid-column: 1;
    }

    .variant-wide .preview-excerpt,
    .variant-wide .preview-tech,
    .variant-wide .preview-actions {
      grid-column: 2;
    }

    .variant-compact {
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      align-items: start;
      gap: var(--space-6);
    }

    .variant-compact .preview-title {
      font-size: var(--font-size-2xl);
    }

    .variant-editorial .cover-link {
      order: 2;
      max-width: 72%;
    }

    .variant-editorial .preview-body {
      order: 1;
    }

    .variant-editorial .preview-title {
      font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-4xl));
    }
  }

  .variant-featured .preview-title {
    font-size: clamp(var(--font-size-3xl), 4.5vw, var(--font-size-5xl));
  }
</style>
