---
interface Props {
  images: string[];
  /** Alt base; se numera cada imagen. */
  altBase: string;
}

const { images, altBase } = Astro.props;
---

{
  images.length > 0 && (
    <div class="project-gallery">
      {images.map((src, i) => (
        <img
          src={src}
          alt={`${altBase} — ${i + 1}`}
          width="1280"
          height="800"
          loading="lazy"
        />
      ))}
    </div>
  )
}

<style>
  .project-gallery {
    display: grid;
    gap: var(--space-5);
  }

  .project-gallery img {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    background: var(--color-surface-soft);
  }

  @media (min-width: 768px) {
    .project-gallery {
      grid-template-columns: repeat(2, 1fr);
    }

    .project-gallery img:first-child:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
