---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../data/company';
import { getCategory } from '../../data/categories';
import { useTranslations, projectPath } from '../../i18n/utils';

interface Props {
  projects: CollectionEntry<'projects'>[];
  locale: Locale;
  label: string;
}

const { projects, locale, label } = Astro.props;
const t = useTranslations(locale);

const slides = projects.map((p) => ({
  href: projectPath(locale, p.data.slug),
  cover: p.data.cover,
  coverAlt: p.data.coverAlt,
  title: p.data.title,
  excerpt: p.data.excerpt,
  kicker: `${getCategory(p.data.category).label[locale]} · ${p.data.year}`,
  example: p.data.example,
  tags: p.data.technologies.slice(0, 3),
}));
---

<div
  class="carousel"
  role="region"
  aria-roledescription="carousel"
  aria-label={label}
  tabindex="0"
>
  <div class="carousel-stage">
    {
      slides.map((slide, i) => (
        <article
          class:list={['carousel-card', { 'is-active': i === 0 }]}
          data-index={i}
        >
          <img
            src={slide.cover}
            alt={slide.coverAlt}
            width="1280"
            height="800"
            loading={i === 0 ? 'eager' : 'lazy'}
            draggable="false"
          />
          <div class="carousel-caption">
            <div class="caption-body">
              <p class="carousel-kicker">
                {slide.kicker}
                {slide.example && <span class="kicker-example">{t('projects.example')}</span>}
              </p>
              <h3 class="carousel-title">
                <a href={slide.href}>{slide.title}</a>
              </h3>
              <p class="carousel-copy">{slide.excerpt}</p>
              {slide.tags.length > 0 && (
                <ul class="carousel-tags">
                  {slide.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </div>
            <a class="carousel-view" href={slide.href} aria-label={`${t('cta.viewProject')}: ${slide.title}`}>
              →
            </a>
          </div>
        </article>
      ))
    }
  </div>

  <div class="carousel-nav">
    <button type="button" class="carousel-arrow" data-dir="-1" aria-label={t('projects.prev')}>
      ←
    </button>
    <div class="carousel-dots" role="tablist">
      {
        slides.map((slide, i) => (
          <button
            type="button"
            class:list={['carousel-dot', { 'is-active': i === 0 }]}
            data-goto={i}
            aria-label={slide.title}
          />
        ))
      }
    </div>
    <button type="button" class="carousel-arrow" data-dir="1" aria-label={t('projects.next')}>
      →
    </button>
  </div>
</div>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('.carousel').forEach((root) => {
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.carousel-card'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.carousel-dot'));
    const stage = root.querySelector<HTMLElement>('.carousel-stage');
    if (cards.length === 0 || !stage) return;

    let index = 0;

    const render = () => {
      const n = cards.length;
      cards.forEach((card, i) => {
        const prev = (index - 1 + n) % n;
        const next = (index + 1) % n;
        card.classList.toggle('is-active', i === index);
        card.classList.toggle('is-prev', n > 2 && i === prev);
        card.classList.toggle('is-next', n > 1 && i === next);
        card.toggleAttribute('inert', i !== index);
      });
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === index));
    };

    const go = (dir: number) => {
      index = (index + dir + cards.length) % cards.length;
      render();
    };

    root.querySelectorAll<HTMLButtonElement>('.carousel-arrow').forEach((btn) => {
      btn.addEventListener('click', () => go(Number(btn.dataset.dir)));
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        index = Number(dot.dataset.goto);
        render();
      });
    });

    root.addEventListener('keydown', (ev) => {
      if (ev.key === 'ArrowLeft') {
        ev.preventDefault();
        go(-1);
      } else if (ev.key === 'ArrowRight') {
        ev.preventDefault();
        go(1);
      }
    });

    /* Arrastre táctil / ratón */
    let startX: number | null = null;

    stage.addEventListener('pointerdown', (ev) => {
      startX = ev.clientX;
      if (!reduced) root.classList.add('is-dragging');
    });

    window.addEventListener('pointerup', (ev) => {
      if (startX === null) return;
      const delta = ev.clientX - startX;
      startX = null;
      root.classList.remove('is-dragging');
      if (Math.abs(delta) > 48) go(delta < 0 ? 1 : -1);
    });

    render();
  });
</script>

<style>
  .carousel {
    max-width: 880px;
    margin-inline: auto;
  }

  .carousel:focus-visible {
    outline: 3px solid var(--color-blue);
    outline-offset: 6px;
    border-radius: var(--radius-xl);
  }

  .carousel-stage {
    position: relative;
    aspect-ratio: 16 / 10;
    touch-action: pan-y;
    perspective: 1200px;
  }

  .carousel-card {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-ink-950);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateX(64px) scale(0.94);
    transition:
      transform var(--duration-slow) var(--ease-standard),
      opacity var(--duration-base) var(--ease-standard);
    pointer-events: none;
  }

  .carousel.is-dragging .carousel-card {
    transition: none;
  }

  .carousel-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }

  .carousel-card.is-active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
    z-index: 3;
  }

  .carousel-card.is-prev {
    opacity: 0.3;
    transform: translateX(-64px) scale(0.94);
    z-index: 2;
  }

  .carousel-card.is-next {
    opacity: 0.3;
    transform: translateX(64px) scale(0.94);
    z-index: 2;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-card {
      transition: opacity var(--duration-fast) linear;
      transform: none;
    }

    .carousel-card.is-prev,
    .carousel-card.is-next {
      opacity: 0;
    }
  }

  .carousel-caption {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    padding: clamp(var(--space-5), 4vw, var(--space-6));
    background: linear-gradient(0deg, rgba(11, 18, 32, 0.94) 20%, rgba(11, 18, 32, 0.55) 65%, transparent);
  }

  .caption-body {
    display: grid;
    gap: var(--space-2);
  }

  .carousel-kicker {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-cyan);
    font-family: var(--font-display);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .kicker-example {
    color: var(--color-warning);
    border: 1px solid currentColor;
    border-radius: var(--radius-pill);
    padding: 1px var(--space-2);
  }

  .carousel-title {
    font-size: clamp(var(--font-size-xl), 3vw, var(--font-size-2xl));
  }

  .carousel-title a {
    color: var(--color-white);
    text-decoration: none;
  }

  .carousel-title a:hover {
    color: var(--color-cyan);
  }

  .carousel-copy {
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--font-size-sm);
    max-width: 46ch;
    display: none;
  }

  @media (min-width: 600px) {
    .carousel-copy {
      display: block;
    }
  }

  .carousel-tags {
    list-style: none;
    margin: var(--space-1) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .carousel-tags li {
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-3);
  }

  .carousel-view {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-size: var(--font-size-xl);
    text-decoration: none;
    transition:
      background-color var(--duration-base) var(--ease-standard),
      border-color var(--duration-base) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .carousel-view:hover {
    background: rgba(98, 66, 252, 0.45);
    border-color: var(--color-violet);
    transform: translateX(3px);
  }

  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    margin-top: var(--space-5);
  }

  .carousel-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-ink-900);
    font-size: var(--font-size-lg);
    display: grid;
    place-items: center;
    transition:
      background-color var(--duration-base) var(--ease-standard),
      border-color var(--duration-base) var(--ease-standard),
      color var(--duration-base) var(--ease-standard);
  }

  .carousel-arrow:hover {
    background: var(--color-ink-900);
    border-color: var(--color-ink-900);
    color: var(--color-white);
  }

  .carousel-dots {
    display: flex;
    gap: var(--space-2);
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: var(--color-border);
    transition:
      background-color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }

  .carousel-dot.is-active {
    background: var(--color-violet);
    transform: scale(1.25);
  }
</style>
