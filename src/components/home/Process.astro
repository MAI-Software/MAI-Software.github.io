---
import type { Locale } from '../../data/company';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const steps = [
  {
    number: '01',
    title: t('process.1.title'),
    text: t('process.1.text'),
    bullets: [t('process.1.b1'), t('process.1.b2'), t('process.1.b3')],
  },
  {
    number: '02',
    title: t('process.2.title'),
    text: t('process.2.text'),
    bullets: [t('process.2.b1'), t('process.2.b2'), t('process.2.b3')],
  },
  {
    number: '03',
    title: t('process.3.title'),
    text: t('process.3.text'),
    bullets: [t('process.3.b1'), t('process.3.b2'), t('process.3.b3')],
  },
];
---

<section class="section process-section">
  <div class="container">
    <header class="section-head" data-reveal>
      <p class="eyebrow">{t('process.eyebrow')}</p>
      <h2>{t('process.title')}</h2>
    </header>

    <ol class="process-grid" data-reveal>
      {
        steps.map((step) => (
          <li class="card process-card" data-tilt>
            <span class="card-chip">{step.number}</span>
            <h3>{step.title}</h3>
            <ul class="card-bullets">
              {step.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process-section {
    border-top: 1px solid var(--color-border-soft);
  }

  .section-head {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }

  .process-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .process-card p {
    color: var(--color-text-muted);
    max-width: 40ch;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
