---
import type { Locale } from '../../data/company';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const steps = [
  { number: '01', title: t('process.1.title'), text: t('process.1.text') },
  { number: '02', title: t('process.2.title'), text: t('process.2.text') },
  { number: '03', title: t('process.3.title'), text: t('process.3.text') },
];
---

<section class="section process-section">
  <div class="container">
    <h2>{t('process.title')}</h2>
    <ol class="process-list">
      {
        steps.map((step) => (
          <li class="process-step">
            <span class="section-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process-section {
    border-top: 1px solid var(--color-border-soft);
  }

  h2 {
    margin-bottom: var(--space-7);
  }

  .process-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-7);
  }

  .process-step {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .process-step p {
    color: var(--color-text-muted);
    max-width: 40ch;
  }

  @media (min-width: 768px) {
    .process-list {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
</style>
