---
import type { Locale } from '../../data/company';
import { useTranslations, contactPath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="section final-cta on-dark">
  <div class="deco deco-blob final-blob" data-parallax="0.16" aria-hidden="true"></div>
  <div class="container final-inner" data-reveal-group>
    <h2 data-reveal>{t('final.title')}</h2>
    <a href={contactPath(locale)} class="btn btn-inverse" data-reveal>{t('cta.contact')}</a>
  </div>
</section>

<style>
  .final-cta {
    background: var(--color-surface-dark);
    position: relative;
    overflow: clip;
  }

  /* Halo de marca discreto (spec §8.2) con parallax */
  .final-blob {
    right: -10%;
    top: -40%;
    background: radial-gradient(
      circle,
      rgba(56, 130, 251, 0.2),
      rgba(98, 66, 252, 0.1) 55%,
      transparent 75%
    );
    filter: none;
  }

  .final-inner {
    display: grid;
    gap: var(--space-6);
    justify-items: start;
    position: relative;
    z-index: var(--z-raised);
  }

  .final-inner h2 {
    max-width: 22ch;
  }
</style>
