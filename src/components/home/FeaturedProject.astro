---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../data/company';
import { getCategory } from '../../data/categories';
import { useTranslations, projectPath } from '../../i18n/utils';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
}

const { project, locale } = Astro.props;
const t = useTranslations(locale);
const data = project.data;
const category = getCategory(data.category);
const href = projectPath(locale, data.slug);
---

<section class="section featured section-dark cut-both">
  <div class="deco deco-blob featured-blob" data-parallax="0.18" aria-hidden="true"></div>

  <div class="container featured-inner">
    <a href={href} class="featured-cover" data-parallax="0.05" tabindex="-1" aria-hidden="true">
      <img src={data.cover} alt={data.coverAlt} width="1280" height="800" loading="lazy" />
    </a>

    <div class="featured-body" data-reveal-group>
      <p class="eyebrow featured-eyebrow" data-reveal>{t('featured.label')}</p>
      <p class="featured-meta" data-reveal>
        <span>{category.label[locale]}</span>
        <span aria-hidden="true">·</span>
        <span>{data.year}</span>
        {data.example && <span class="badge badge-example">{t('projects.example')}</span>}
      </p>
      <h2 data-reveal>
        <a href={href} class="featured-title-link">{data.title}</a>
      </h2>
      <p class="featured-excerpt" data-reveal>{data.excerpt}</p>
      {
        data.technologies.length > 0 && (
          <ul class="featured-tags" data-reveal aria-label={t('projects.tech')}>
            {data.technologies.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        )
      }
      <div class="featured-actions" data-reveal>
        <a href={href} class="btn btn-gradient">{t('cta.viewProject')}</a>
        {
          data.demoUrl && (
            <a href={data.demoUrl} class="btn btn-ghost-dark" target="_blank" rel="noopener noreferrer">
              {t('cta.openDemo')} ↗
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .featured {
    padding-block: clamp(var(--space-9), 12vw, calc(var(--space-10) + 2rem));
  }

  .featured-blob {
    top: -15%;
    left: -10%;
  }

  .featured-inner {
    display: grid;
    gap: var(--space-7);
    align-items: center;
  }

  .featured-cover {
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 0 80px rgba(56, 130, 251, 0.22),
      0 32px 80px rgba(0, 0, 0, 0.5);
  }

  .featured-cover img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-standard);
  }

  @media (hover: hover) {
    .featured-cover:hover img {
      transform: scale(1.03);
    }
  }

  .featured-body {
    display: grid;
    gap: var(--space-4);
    justify-items: start;
  }

  .featured-eyebrow {
    color: var(--color-cyan);
  }

  .featured-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.65);
    font-size: var(--font-size-sm);
  }

  .featured-title-link {
    color: var(--color-white);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-standard);
  }

  .featured-title-link:hover {
    color: var(--color-cyan);
  }

  .featured-excerpt {
    color: rgba(255, 255, 255, 0.75);
    max-width: 48ch;
  }

  .featured-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .featured-tags li {
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-3);
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  @media (min-width: 900px) {
    .featured-inner {
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
      gap: var(--space-8);
    }
  }
</style>
