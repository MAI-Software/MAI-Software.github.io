---
import type { Locale } from '../../data/company';
import { categories } from '../../data/categories';
import { useTranslations } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const bulletKeys = (id: string): UIKey[] =>
  [`category.${id}.b1`, `category.${id}.b2`, `category.${id}.b3`] as UIKey[];
---

<section class="section">
  <div class="container">
    <header class="section-head" data-reveal>
      <p class="eyebrow">{t('categories.eyebrow')}</p>
      <h2>{t('categories.title')}</h2>
    </header>

    <ol class="category-grid" data-reveal-group>
      {
        categories.map((cat) => (
          <li class="card category-card" data-reveal>
            <span class="section-number">{cat.number}</span>
            <h3>{cat.label[locale]}</h3>
            <p class="category-desc">{cat.description[locale]}</p>
            <ul class="card-bullets">
              {bulletKeys(cat.id).map((key) => (
                <li>{t(key)}</li>
              ))}
            </ul>
            <a href={cat.path[locale]} class="link-editorial category-link">
              {t('categories.cta')}
            </a>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section-head {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }

  .section-head h2 {
    max-width: 22ch;
  }

  .category-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .category-card h3 {
    font-size: clamp(var(--font-size-xl), 3vw, var(--font-size-2xl));
  }

  .category-desc {
    color: var(--color-text-muted);
  }

  .category-link {
    margin-top: var(--space-2);
    justify-self: start;
  }

  @media (min-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
