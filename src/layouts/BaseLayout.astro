---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import spaceGroteskWoff2 from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/typography.css';

import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import ContactCTA from '../components/global/ContactCTA.astro';
import { company, type Locale } from '../data/company';
import { useTranslations } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Ruta equivalente en el otro idioma, para hreflang y el conmutador. */
  alternatePath?: string;
  ogImage?: string;
  /** Ocultar CTA móvil (p. ej. en la propia página de contacto). */
  hideContactCta?: boolean;
}

const {
  locale,
  title,
  description,
  alternatePath,
  ogImage = '/social/og-default.jpg',
  hideContactCta = false,
} = Astro.props;

const t = useTranslations(locale);
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const alternateLocale: Locale = locale === 'es' ? 'en' : 'es';
const alternateUrl = alternatePath ? new URL(alternatePath, Astro.site) : null;
const xDefaultUrl = locale === 'es' ? canonical : alternateUrl;

// Datos estructurados: solo hechos reales (spec §19/§32)
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: company.name,
      url: Astro.site?.toString(),
      logo: new URL('/icon-512.png', Astro.site).toString(),
      sameAs: [company.social.github].filter(Boolean),
    },
    {
      '@type': 'WebSite',
      name: company.name,
      url: Astro.site?.toString(),
      inLanguage: ['es', 'en'],
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0B1220" />

    <link rel="preload" as="font" type="font/woff2" href={spaceGroteskWoff2} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />

    {alternateUrl && <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />}
    {alternateUrl && <link rel="alternate" hreflang={locale} href={canonical} />}
    {xDefaultUrl && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={company.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <div class="progress-track" aria-hidden="true"><div class="progress-fill"></div></div>
    <a href="#main" class="skip-link">{t('skip.content')}</a>
    <Header locale={locale} alternatePath={alternatePath} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    {!hideContactCta && <ContactCTA locale={locale} />}
    <script src="../scripts/motion.ts"></script>
  </body>
</html>
