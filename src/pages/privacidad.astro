---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
import { useTranslations } from '../i18n/utils';

const locale = 'es';
const t = useTranslations(locale);
---

<BaseLayout
  locale={locale}
  title={`${t('privacy.title')} — ${company.name}`}
  description={t('privacy.text')}
  alternatePath="/en/privacy"
>
  <section class="section">
    <div class="container">
      <div class="container-reading privacy-page">
        <h1>{t('privacy.title')}</h1>
        <p>{t('privacy.text')}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .privacy-page {
    display: grid;
    gap: var(--space-5);
    min-height: 40vh;
  }

  .privacy-page p {
    color: var(--color-text-muted);
  }
</style>
