---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectArchive from '../../components/projects/ProjectArchive.astro';
import { company } from '../../data/company';
import { getCategory } from '../../data/categories';
import { getProjects } from '../../lib/projects';

const locale = 'en';
const category = getCategory('saas');
const projects = await getProjects(locale, 'saas');
---

<BaseLayout
  locale={locale}
  title={`${category.label.en} — ${company.name}`}
  description={category.intro.en}
  alternatePath="/saas"
>
  <ProjectArchive
    locale={locale}
    title={category.label.en}
    intro={category.intro.en}
    projects={projects}
    activeCategory="saas"
  />
</BaseLayout>
