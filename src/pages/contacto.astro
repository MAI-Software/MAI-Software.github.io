---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
import { useTranslations } from '../i18n/utils';

const locale = 'es';
const t = useTranslations(locale);

const socialLinks = [
  { label: 'GitHub', url: company.social.github },
  { label: 'LinkedIn', url: company.social.linkedin },
  { label: 'X', url: company.social.x },
  { label: 'Instagram', url: company.social.instagram },
  { label: 'YouTube', url: company.social.youtube },
].filter((s) => s.url !== '');
---

<BaseLayout
  locale={locale}
  title={`Contacto — ${company.name}`}
  description={t('contact.text')}
  alternatePath="/en/contact"
  hideContactCta
>
  <section class="section contact-page tech-grid-bg">
    <div class="container contact-inner">
      <span class="brand-rule" aria-hidden="true"></span>
      <h1>{t('contact.title')}</h1>
      <p class="lead">{t('contact.text')}</p>

      {
        company.contact.email ? (
          <a href={`mailto:${company.contact.email}`} class="btn btn-primary contact-email">
            {company.contact.email}
          </a>
        ) : (
          <p class="pending-note">{t('contact.email.pending')}</p>
        )
      }

      {
        socialLinks.length > 0 && (
          <ul class="contact-social">
            {socialLinks.map((s) => (
              <li>
                <a href={s.url} class="link-editorial" target="_blank" rel="noopener noreferrer">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    min-height: 60vh;
  }

  .contact-inner {
    display: grid;
    gap: var(--space-6);
    justify-items: start;
    max-width: var(--container-reading);
  }

  .contact-inner h1 {
    font-size: clamp(var(--font-size-4xl), 5.5vw, var(--font-size-5xl));
  }

  .pending-note {
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }

  .contact-social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }
</style>
