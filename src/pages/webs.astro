---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectArchive from '../components/projects/ProjectArchive.astro';
import { company } from '../data/company';
import { getCategory } from '../data/categories';
import { getProjects } from '../lib/projects';

const locale = 'es';
const category = getCategory('web');
const projects = await getProjects(locale, 'web');
---

<BaseLayout
  locale={locale}
  title={`${category.label.es} — ${company.name}`}
  description={category.intro.es}
  alternatePath="/en/webs"
>
  <ProjectArchive
    locale={locale}
    title={category.label.es}
    intro={category.intro.es}
    projects={projects}
    activeCategory="web"
  />
</BaseLayout>
